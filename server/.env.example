# Copy this file to ".env" and fill in your own Amadeus for Developers keys.
# Get them from https://developers.amadeus.com -> My Self-Service Workspace -> your app.
# Never commit the real .env file to git.

AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# test.api.amadeus.com = free sandbox (fake/limited data, safe to start with)
# api.amadeus.com      = production (real live data, requires an approved paid app)
AMADEUS_BASE_URL=https://test.api.amadeus.com

PORT=8787
