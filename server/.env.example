# Copy this file to ".env" and fill in your own Duffel API token.
# Get it from https://duffel.com -> sign up -> Dashboard -> Developer test mode -> API tokens.
# Never commit the real .env file to git.

# Test tokens start with "duffel_test_" (free, uses Duffel's fake test airline/hotel — safe to start with).
# Live tokens start with "duffel_live_" (real bookable data, requires a live/production Duffel account).
DUFFEL_API_TOKEN=duffel_test_your_token_here

PORT=8787
